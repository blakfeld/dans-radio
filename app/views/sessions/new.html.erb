<%= render 'shared/navigation', current_page: 'login' %>

<div class="login-page">
  <div class="login-container card">
    <div class="login-header">
      <h2>Sign in to your account</h2>
    </div>

    <%= form_with(url: login_path, local: true, class: "login-form pure-form pure-form-stacked") do |f| %>
      <fieldset>
        <div class="pure-control-group">
          <%= f.label :login, "Email or Username" %>
          <%= f.text_field :login,
                           autocomplete: "username",
                           required: true,
                           class: "pure-input-1",
                           placeholder: "Enter your email or username" %>
        </div>

        <div class="pure-control-group">
          <%= f.label :password %>
          <%= f.password_field :password,
                               autocomplete: "current-password",
                               required: true,
                               class: "pure-input-1",
                               placeholder: "Enter your password" %>
        </div>

        <div class="pure-control-group remember-me-group">
          <label for="remember_me" class="pure-checkbox">
            <%= f.check_box :remember_me %>
            Remember me
          </label>
        </div>

        <%= f.submit "Sign in",
                     class: "pure-button pure-button-primary pure-input-1" %>
      </fieldset>
    <% end %>
  </div>
</div>

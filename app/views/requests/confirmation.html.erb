<%= render 'shared/navigation', current_page: 'requests' %>

<div class="confirmation-message">
  <h2>🎉 Request Received!</h2>

  <% if @request %>
    <p>
      Your request for <strong>"<%= @request.track_title %>"</strong>
      by <strong><%= @request.artist %></strong> has been added to the queue.
    </p>

    <% if @queue_position %>
      <p style="font-size: 1.5rem; margin: 2rem 0;">
        Queue Position: <strong>#<%= @queue_position %></strong>
      </p>
    <% end %>
  <% else %>
    <p>Your song request has been received and will be played soon!</p>
  <% end %>

  <p style="margin-top: 2rem;">You can make another request in 5 minutes.</p>
</div>

<div class="card" style="text-align: center;">
  <h3>What would you like to do next?</h3>

  <div class="pure-g">
    <div class="pure-u-1 pure-u-md-1-3">
      <%= link_to "Now Playing", now_playing_path,
          class: "pure-button pure-button-primary",
          style: "width: 90%; margin: 0.5rem;" %>
    </div>
    <div class="pure-u-1 pure-u-md-1-3">
      <%= link_to "Browse More Music", browse_path,
          class: "pure-button",
          style: "width: 90%; margin: 0.5rem;" %>
    </div>
    <div class="pure-u-1 pure-u-md-1-3">
      <%= link_to "View Queue", queue_path,
          class: "pure-button",
          style: "width: 90%; margin: 0.5rem;" %>
    </div>
  </div>
</div>

<script>
  // Auto-redirect to Now Playing after 10 seconds
  setTimeout(function() {
    window.location.href = '<%= now_playing_path %>';
  }, 10000);
</script>

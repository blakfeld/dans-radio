<div style="text-align: center; padding: 50px;">
  <h1>Spotify Authentication</h1>

  <p>Click the link below to authenticate with Spotify:</p>

  <%= link_to "Login with Spotify", "/auth/spotify",
      class: "btn",
      style: "display: inline-block; padding: 15px 30px; background-color: #1DB954; color: white; text-decoration: none; border-radius: 25px; font-size: 18px; margin: 20px;" %>

  <div style="margin-top: 40px; padding: 20px; background-color: #f5f5f5; border-radius: 10px; max-width: 600px; margin-left: auto; margin-right: auto;">
    <h3>Debug Info:</h3>
    <p><strong>Current Host:</strong> <%= request.host_with_port %></p>
    <p><strong>Protocol:</strong> <%= request.protocol %></p>
    <p><strong>Full URL for OAuth:</strong> <%= request.protocol + request.host_with_port %>/auth/spotify</p>
    <p><strong>Expected Callback:</strong> <%= request.protocol + request.host_with_port %>/auth/spotify/callback</p>

    <hr style="margin: 20px 0;">

    <p><strong>Important:</strong> Make sure this callback URL is registered in your Spotify app:</p>
    <code style="background-color: white; padding: 10px; display: block; margin: 10px 0;">
      <%= request.protocol + request.host_with_port %>/auth/spotify/callback
    </code>
  </div>

  <% if SpotifyUser.any? %>
    <div style="margin-top: 20px;">
      <p>Already authenticated users:</p>
      <ul style="list-style: none;">
        <% SpotifyUser.all.each do |user| %>
          <li><%= user.username %> - <%= user.email %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

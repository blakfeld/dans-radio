<div class="admin-header">
  <h1>Admin Dashboard</h1>
  <p>Manage your radio station content and requests</p>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <h3>Total Artists</h3>
    <div class="stat-value"><%= @total_artists %></div>
  </div>

  <div class="stat-card">
    <h3>Total Tracks</h3>
    <div class="stat-value"><%= @total_tracks %></div>
  </div>

  <div class="stat-card">
    <h3>Total Albums</h3>
    <div class="stat-value"><%= @total_albums %></div>
  </div>

  <div class="stat-card">
    <h3>Pending Requests</h3>
    <div class="stat-value" style="color: #ff6b6b;"><%= @pending_requests %></div>
  </div>

  <div class="stat-card">
    <h3>Total Users</h3>
    <div class="stat-value"><%= @total_users %></div>
    <div style="font-size: 0.9rem; color: #666; margin-top: 0.5rem;">
      Admins: <%= @admin_users %> | Locked: <%= @locked_users %>
    </div>
  </div>

  <div class="stat-card">
    <h3>Quick Actions</h3>
    <div style="margin-top: 0.5rem;">
      <%= link_to "Manage Users", admin_users_path, class: "pure-button pure-button-sm pure-button-primary", style: "margin: 2px;" %>
      <%= link_to "Add User", new_admin_user_path, class: "pure-button pure-button-sm", style: "margin: 2px;" %>
      <%= link_to "Setup", setup_index_path, class: "pure-button pure-button-sm", style: "margin: 2px;" %>
    </div>
  </div>
</div>

<% if @currently_playing %>
  <div class="card">
    <h2>Currently Playing</h2>
    <p>
      <strong><%= @currently_playing.track_title %></strong> by <%= @currently_playing.artist %>
      <span class="status-badge status-playing">Playing</span>
    </p>
  </div>
<% end %>

<div class="card">
  <h2>Recent Requests</h2>

  <% if @recent_requests.any? %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Track</th>
          <th>Artist</th>
          <th>Status</th>
          <th>Requested</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_requests.each do |request| %>
          <tr>
            <td><%= request.track_title %></td>
            <td><%= request.artist %></td>
            <td>
              <span class="status-badge status-<%= request.status %>">
                <%= request.status.capitalize %>
              </span>
            </td>
            <td><%= time_ago_in_words(request.created_at) %> ago</td>
            <td>
              <%= link_to "View", admin_song_request_path(request), class: "pure-button pure-button-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div style="text-align: center; margin-top: 1rem;">
      <%= link_to "View All Requests", admin_song_requests_path, class: "pure-button pure-button-primary" %>
    </div>
  <% else %>
    <p>No requests yet.</p>
  <% end %>
</div>
